<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trade History</title>
    <link rel='shortcut icon' type='image/x-icon' href='/images/favicon.ico'>
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="https://itsinhaleyo.online/css/header.css">
    <link rel="stylesheet" href="https://itsinhaleyo.online/css/tradehistory.css">
    <script src="https://itsinhaleyo.online/script/tradehistory.js" defer></script>
</head>
<body>
    <%- include('header') %>
    <div class="container">
        <h1>Trade History</h1>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-bottom: 25px;">
            <div class="stat-card summary-box">
                <div class="label">Total Profit</div>
                <div class="value" style="color: <%= totalPnL >= 0 ? '#10b981' : '#ef4444' %>">
                    <%= totalPnL >= 0 ? '+' : '' %>💰<%= Math.round(totalPnL).toLocaleString() %>
                </div>
            </div>
            <div class="stat-card summary-box">
                <div class="label">Win Rate</div>
                <div class="value" style="color: #6366f1;"><%= winRate %>%</div>
            </div>
            <div class="stat-card summary-box">
                <div class="label">Closed Trades</div>
                <div class="value" style="color: white;"><%= totalTrades %></div>
            </div>
        </div>
        <div style="margin-bottom: 20px;">
            <label>Filter by Asset: </label>
            <select id="assetFilter" class="asset-select" onchange="filterHistory()">
                <option value="ALL">All Assets</option>
                <% uniqueSymbols.forEach(sym => { %>
                    <option value="<%= sym %>"><%= sym %></option>
                <% }) %>
            </select>
        </div>
        <div class="history-card">
            <table>
                <thead>
                    <tr>
                        <th>Date</th><th>Asset</th><th>Action</th><th>Side</th><th>Size</th><th>Price</th><th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (logs.length > 0) { %>
                        <% logs.forEach(log => { 
                            const action = log.action.toUpperCase();
                            const isClose = action.includes('SELL') || action.includes('CLOSE') || action.includes('STOP') || action.includes('PROFIT') || action.includes('AUTO');
                            const isBuy = action === 'BUY' || action === 'OPEN';
                            
                            let actionColor = '#94a3b8';
                            if (isBuy || action.includes('TP')) actionColor = '#10b981';
                            else if (action.includes('SL') || isClose) actionColor = '#ef4444';
                            else if (action.includes('LIQ')) actionColor = '#f59e0b';
                        %>
                            <tr class="log-row" data-symbol="<%= log.symbol.toUpperCase() %>">
                                <td style="font-size: 0.8rem; color: var(--text-muted);">
                                    <%= new Date(log.timestamp).toLocaleString() %>
                                </td>
                                <td><strong><%= log.symbol.toUpperCase() %></strong></td>
                                <td style="color: <%= actionColor %>; font-weight: bold;"><%= action %></td>
                                <td style="color: <%= log.side === 'LONG' ? '#10b981' : '#ef4444' %>;"><%= log.side %></td>
                                <td><%= Number(log.amount).toLocaleString() %></td>
                                <td>$<%= Number(log.price_per_share).toLocaleString() %></td>
                                <td>
                                    💰<%= Number(log.total_cost).toLocaleString() %>
                                    <% if (isClose) { %>
                                        <div style="color: <%= log.pnl >= 0 ? '#10b981' : '#ef4444' %>; font-size: 0.7rem; font-weight: 600;">
                                            <%= log.pnl >= 0 ? '+' : '' %>💰<%= Math.round(log.pnl).toLocaleString() %>
                                        </div>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="7" style="text-align:center; padding:20px;">No trade history found.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>