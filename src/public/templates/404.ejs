<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>404 - Page Not Found</title>
    <link rel='shortcut icon' type='image/x-icon' href='/images/favicon.ico'>
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="https://itsinhaleyo.online/css/header.css">
    <link rel="stylesheet" href="https://itsinhaleyo.online/css/404.css">
</head>
<body>
    <%- include('header') %>
    <div class="error-container">
        <h1 class="error-code"><%= typeof errorCode !== 'undefined' ? errorCode : '404' %></h1>
        <h2><%= typeof errorMessage !== 'undefined' ? errorMessage : "Oops! This page doesn't exist." %></h2>
        <a href="/" class="btn-home">Home Page</a>
        <footer>
            <div class="status-badge">● Secure via Cloudflare</div>
        </footer>
    </div>
</body>
</html>