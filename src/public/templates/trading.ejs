<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crypto Trading | <%= share %></title>
    <%- include('icon') %>
    <link rel="stylesheet" href="https://itsinhaleyo.online/css/header.css">
    <link rel="stylesheet" href="https://itsinhaleyo.online/css/trading.css">
    <script src="https://itsinhaleyo.online/script/trading.js" defer></script>
</head><body>
    <%- include('header') %>
    <div class="trading-layout">
        <div class="chart-container">
            <div class="stat-card chart-wrapper">
                <iframe id="geckoterminal-embed" title="GeckoTerminal"
                    src="<%= contractlink %>?embed=1&info=0&swaps=0&light_chart=0&chart_type=price&resolution=1s&bg_color=111827" 
                    frameborder="0" allow="clipboard-write" allowfullscreen style="width: 100%; height: 100%; border: none;">
                </iframe>
            </div>
        </div>
        <div class="sidebar">
            <div class="stat-card">
                <div class="stat-label">Balance</div>
                <div id="balance" class="stat-value">💰 <%= balance %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Market Order</div>
                <input id="amount" type="number" placeholder="Amount" class="trade-input">
                <div class="leverage-container">
                    <div class="leverage-header">
                        <span>Leverage</span>
                        <span id="lev-display">1x (Spot)</span>
                    </div>
                    <input type="range" id="leverage" class="leverage-slider" min="1" max="100" value="1" 
                        oninput="document.getElementById('lev-display').innerText = this.value + 'x'">
                </div>
                <div class="btn-group">
                    <button onclick="trade('LONG')" class="btn-buy">Long</button>
                    <button onclick="trade('SHORT')" class="btn-sell">Short</button>
                </div>
                <p id="trade-status" style="margin-top: 10px; font-size: 0.8rem; text-align: center;"></p>
            </div>
        </div>
    </div>
    <div class="orders-container">
        <div class="orders-header">
            <span>Open Positions</span>
            <span id="marketprice">Market Price: fetching...</span>
        </div>
        <table class="orders-table">
            <thead>
                <tr>
                    <th>Asset</th>
                    <th>Size</th>
                    <th>Entry Price</th>
                    <th>Take Profit</th>
                    <th>Stop Loss</th>
                    <th>Liq. Price</th>
                    <th>Lev</th>
                    <th>PnL</th>
                    <th style="text-align: right;">Action</th>
                </tr>
            </thead>
            <tbody>
                <% if (allHoldings && allHoldings.length > 0) { %>
                    <% allHoldings.forEach(pos => { %>
                        <tr class="position-row" 
                            data-symbol="<%= pos.symbol %>" 
                            data-entry="<%= pos.average_price %>" 
                            data-shares="<%= pos.shares %>" 
                            data-side="<%= pos.side %>" 
                            data-margin="<%= pos.margin_used %>" 
                            data-leverage="<%= pos.leverage %>"
                            data-network="<%= pos.network %>"
                            data-contract="<%= pos.contract %>">
                            <td class="mobile-card-header">
                                <div class="symbol-name"><%= pos.symbol.toUpperCase() %></div>
                                <div class="side-badge <%= pos.side.toLowerCase() %>"><%= pos.side %></div>
                            </td>
                            <td data-label="Amount"><%= Number(pos.shares).toLocaleString() %></td>
                            <td data-label="Entry Price">$<%= Number(pos.average_price).toLocaleString() %></td>
                            <td data-label="Take Profit">
                                <div class="limit-input-group">
                                    <input type="number" id="tp-<%= pos.symbol %>" class="tp-field" placeholder="TP" value="<%= pos.take_profit || '' %>">
                                    <button class="set-btn tp" onclick="updateLimits('<%= pos.symbol %>', document.getElementById('tp-<%= pos.symbol %>').value, 'tp', this)">SET</button>
                                </div>
                            </td>
                            <td data-label="Stop Loss">
                                <div class="limit-input-group">
                                    <input type="number" id="sl-<%= pos.symbol %>" class="sl-field" placeholder="SL" value="<%= pos.stop_loss || '' %>">
                                    <button class="set-btn sl" onclick="updateLimits('<%= pos.symbol %>', document.getElementById('sl-<%= pos.symbol %>').value, 'sl', this)">SET</button>
                                </div>
                            </td>
                            <td data-label="Liq. Price" class="pos-liq" style="color: #f59e0b;">---</td>
                            <td data-label="Leverage"><%= pos.leverage %>x</td>
                            <td data-label="PnL" class="pos-pnl">Calculating...</td>
                            <td class="mobile-action-cell">
                                <button onclick="closePosition('<%= pos.symbol %>', '<%= pos.network %>', '<%= pos.contract %>', <%= pos.shares %>)" class="btn-close-ghost">
                                    Close Position
                                </button>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="9" class="empty-state">No open positions</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
    <input type="hidden" id="network" value="<%= coin.network %>">
    <input type="hidden" id="contract" value="<%= coin.contract %>">
    <input type="hidden" id="coinid" value="<%= share %>">
    <input type="hidden" id="display-shares" value="<%= ownedshares %>">
    <input type="hidden" id="userid" value="<%= user.userid %>">
    <input type="hidden" id="live-value">
</body>
</html>